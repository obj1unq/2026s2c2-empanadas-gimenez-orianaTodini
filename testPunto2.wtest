import empleados.*

test "Qué hacen los empleados con lo que cobran" {
	
  baigorria.venta(500)
  galvan.nuevoSueldo(20000)
  baigorria.venta(300)
  
  gimenez.empleado(baigorria)
  gimenez.pagarSueldo()
  gimenez.empleado(galvan)
  gimenez.pagarSueldo()
  
  baigorria.venta(100)
  gimenez.empleado(baigorria)
  gimenez.pagarSueldo()
  assert.equals(13500, baigorria.totalCobrado())
  
 	
}