import empleados.*

test "punto1: Planteo inicial" {

  baigorria.venta(500)
  baigorria.venta(300)
  assert.equals(12000, baigorria.sueldo())
  assert.equals(20000, galvan.sueldo())
  gimenez.empleado(baigorria)
  gimenez.pagarSueldo()
  gimenez.empleado(galvan)
  gimenez.pagarSueldo()
  assert.equals(268000, gimenez.fondoActual())
  
}

